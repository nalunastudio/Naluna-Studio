# Stocare fisiere media — Cloudflare R2 sau AWS S3, in DOUA bucket-uri separate.
# FARA acestea setate, aplicatia foloseste automat discul local ca fallback — util pentru
# testare, dar NU recomandat pe Railway pentru productie (fisierele se pierd la redeploy).
# Pasii de configurare exacti, pentru R2 si pentru S3, sunt in comentariile din storage.js.
#
# S3_PRIVATE_BUCKET — DOAR melodiile complete. Fara acces public, niciodata. Acces exclusiv
# prin URL semnat (presigned), generat dupa ce clientul a platit.
S3_PRIVATE_BUCKET=naluna-private
#
# S3_PUBLIC_BUCKET — preview-uri si reactii clienti (testimoniale). Acces public, prin
# Custom Domain Cloudflare (vezi S3_PUBLIC_BASE_URL mai jos).
S3_PUBLIC_BUCKET=naluna-public
#
# Acelasi API token (Access Key + Secret) poate avea acces la ambele bucket-uri —
# le creezi o singura data, cu scop "Apply to specific buckets" -> selectezi ambele.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
#
# URL-ul public (Custom Domain) al bucket-ului S3_PUBLIC_BUCKET — NU al celui privat.
# Bucket-ul privat nu are niciodata un URL public.
S3_PUBLIC_BASE_URL=https://media.naluna.co.uk

# Baza de date PostgreSQL — pe Railway se injecteaza AUTOMAT cand adaugi
# un serviciu PostgreSQL din dashboard (New -> Database -> PostgreSQL).
# Local: postgres://user:parola@localhost:5432/nume_baza
DATABASE_URL=postgres://user:parola@localhost:5432/nota_de_suflet

# Stripe (dashboard.stripe.com -> Developers -> API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Domeniul unde e publicat site-ul (fara slash la final)
DOMAIN=https://naluna.co.uk

# Provider API de generare muzica (alege unul: sunoapi.org / apiframe.ai / aimlapi.com)
MUSIC_API_BASE_URL=https://api.sunoapi.org/v1
MUSIC_API_KEY=...

# Email de livrare (resend.com - cont gratuit pana la 3000 emailuri/luna)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=comenzi@domeniul-tau.ro

# Login owner - acces la /admin (panou comenzi si venit)
ADMIN_USER=admin
ADMIN_PASSWORD=schimba-parola-asta

PORT=3000
